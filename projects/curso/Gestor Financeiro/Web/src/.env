# Porta do Servidor BFF
PORT=3001

# Ambiente de execução
NODE_ENV=development

# Origens permitidas para requisições CORS
# Use * para permitir todas as origens
CORS_ORIGIN=*

# Configuração da API Horse
# URL base do servidor Horse (Delphi REST API)
HORSE_API_BASE_URL=http://localhost:9000

# Chave secreta para autenticação de tokens JWT
# IMPORTANTE: Em produção, use uma chave loga e aleatória, e não compartilhe publicamente.
HORSE_JWT_SECRET=c7f9a1b2-48d3-4e2a-9d8a-2f1e6c4a9b7d